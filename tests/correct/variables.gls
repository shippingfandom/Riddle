;; null
(def a null)
;; number
(def b 1)
;; string
(def c 'test')
;; list
(def d (array a b c))
;; list index assignment
(set d 0 a)
(set d b b)
;; list index
(at d 0)
(at d b)
;; map
(def e (dict 'null' a 'number' b 'string' c 'list' d))
;; map index
(at e 'number')
;; map index assignment
(set e 'map' e)
;; empty list
(def empty (array))
;; empty map
(def empty (dict))