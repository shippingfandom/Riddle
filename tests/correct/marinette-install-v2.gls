(defun RandomAffirmation () (begin
    (def affirmations (array 'Good is good enough' 'Kindness connects people' 'Every mistake is a lesson' 'Compassion needs no reason' 'Today holds quiet good things' 'Small steps lead to big change' 'Growth happens in stillness too' 'Help given freely lifts everyone' 'The world is full of second chances'))
    ((at affirmations 'shuffle') affirmations)
    ((at affirmations 'pull') affirmations)))
(defun AvailableUsers () (begin
    (def users (array))
    (if (== (typeof ((at (at globals 'command') 'file') '-r' '/home')) 'file') (begin
    (def homeDirectory ((at ((at (at globals 'command') 'ls') '-r' '/home') 'split') ((at (at globals 'command') 'ls') '-r' '/home') (char 10)))
    (foreach _ user homeDirectory (begin
    ((at users 'push') users ((at user 'trim') user))))))
    users))
(defun MainMenu () (begin
    ((at (at globals 'command') 'clear'))
    (def header (array '<u>Marinette installation script (0.0 )</u>' '' 'Please choose an option below!' '' '1. User install [Install for non-root user]' '2. Bash install [Install as your bash replacement]' 'q. Quit the installation script' ''))
    (gl-break-silence ((at header 'join') header (char 10)))
    (def choice (to_int (user_input ':: ')))
    (if (== choice 1) (begin
    (UserInstallMenu))
(if (== choice 2) (begin
    (BashInstall))
(if (== choice 'q') (begin
    'Удачкиии~ .( ^.^)v')
(begin
    (gl-break-silence 'Incorrect choice!')
    ((at (at globals 'command') 'pause') '-m')
    (MainMenu)))))))
(defun UserInstallMenu () (begin
    (def users (AvailableUsers))
    ((at (at globals 'command') 'clear'))
    (def header (array '<u>User install mode</u>' '' 'Select which user you want to install Marinette for!' ''))
    (def choices (array))
    (foreach index user users (begin
    ((at header 'push') header (+ (+ (+ index 1) '. ') user))
    ((at choices 'push') choices (+ index 1))))
    ((at header 'push') header 'q. Back to the main menu')
    ((at header 'push') header '')
    (gl-break-silence ((at header 'join') header (char 10)))
    (def choice (to_int (user_input ':: ')))
    (if (!= ((at choices 'indexOf') choices choice) null) (begin
    (UserInstall (at users (- choice 1))))
(if (== choice 'q') (begin
    (MainMenu))
(begin
    (gl-break-silence 'Incorrect choice!')
    ((at (at globals 'command') 'pause') '-m')
    (UserInstallMenu))))))
(defun UserInstall (user) (begin
    ((at (at globals 'command') 'clear'))
    (def affirmation (RandomAffirmation))
    (def header (array '<u>An important warning!</u>' '' 'You are about to be faced with <b>kore -r</b> prompt' 'In this prompt, you absolutely must simply press enter for a quick install!' 'If you understand this, please enter this simple affirmation I have prepaired for you <3' '' (+ (+ '<b>' affirmation) '</b>') ''))
    (gl-break-silence ((at header 'join') header (char 10)))
    (while (!= affirmation (user_input ':: ')) (begin
    (gl-break-silence 'You filled an affirmation incorrectly!')
    (gl-break-silence 'Please try again, you got this!!!')))
    ((at (at globals 'command') 'kore') '-r')
    (def userHome (gl-pathcat (array '/home' user)))
    ((at (at globals 'command') 'cp') '/root/rkit' userHome)
    (def userRkit (gl-pathcat (array userHome 'rkit')))
    ((at (at globals 'command') 'usr') '-r' 'guest' userRkit)
    ((at (at globals 'command') 'grp') '-r' 'guest' userRkit)
    ((at (at globals 'command') 'perms') '-r' 'o+rwx' userRkit)
    ((at (at globals 'command') 'perms') '-r' 'g+rwx' userRkit)
    ((at (at globals 'command') 'perms') '-r' 'u+rwx' userRkit)
    (gl-break-silence '')
    (mari-printline 'User install is done!')
    ((at (at globals 'command') 'pause') '-m')
    (UserInstallMenu)))
(defun BashInstall () (begin
    ((at (at globals 'command') 'clear'))
    (def affirmation (RandomAffirmation))
    (def header (array '<u>An important warning!</u>' '' 'As <b>/bin/bash</b>, <b>5hell</b> will load <b>Marinette</b> only from your user home directory!' 'So, if you have not done it already, you absolutely must perform user install for your computer user after this!' 'If you understand this, please enter this simple affirmation I have prepaired for you <3' '' (+ (+ '<b>' affirmation) '</b>') ''))
    (gl-break-silence ((at header 'join') header (char 10)))
    (while (!= affirmation (user_input ':: ')) (begin
    (gl-break-silence 'You filled an affirmation incorrectly!')
    (gl-break-silence 'Please try again, you got this!!!')))
    (def shell (program_path))
    ((at (at globals 'command') 'cp') shell '/bin/bash')
    ((at (at globals 'command') 'usr') '-r' 'root' '/bin/bash')
    ((at (at globals 'command') 'grp') '-r' 'root' '/bin/bash')
    ((at (at globals 'command') 'perms') '-r' 'o-rwx' '/bin/bash')
    ((at (at globals 'command') 'perms') '-r' 'g-rwx' '/bin/bash')
    ((at (at globals 'command') 'perms') '-r' 'u-rwx' '/bin/bash')
    (gl-break-silence '')
    (mari-printline 'Bash install is done!')
    ((at (at globals 'command') 'pause') '-m')
    (MainMenu)))
(if (!= ((at (at globals 'command') 'whoami')) 'root') (begin
    (mari-printline 'Root access is neccessary for this script!')
    null)
(begin
    (MainMenu)))