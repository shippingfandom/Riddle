(def multiplayer? false)
(def silentState (at globals 'SILENT'))
(if (== (typeof ((at (at globals 'command') 'file') '-r' '/usr/bin/Chat.exe')) 'file') (begin
    (def multiplayer? true)))
(set globals 'SILENT' silentState)
(defun RandomAffirmation () (begin
    (def affirmations (array 'Good is good enough' 'Kindness connects people' 'Every mistake is a lesson' 'Compassion needs no reason' 'Today holds quiet good things' 'Small steps lead to big change' 'Growth happens in stillness too' 'Help given freely lifts everyone' 'The world is full of second chances'))
    ((at affirmations 'shuffle') affirmations)
    ((at affirmations 'pull') affirmations)))
(defun IsNetworkReachable () (begin
    (!= ((at ((at (at globals 'command') 'ifconfig')) 'trim') ((at (at globals 'command') 'ifconfig'))) 'No active network connection.')))
(defun NoNetworkLogic () (begin
    (mari-printline 'No network connection, running the no network logic...')
    (def affirmation (RandomAffirmation))
    (def header (array '<u>An important warning!</u>' '' 'You are about to be faced with <b>air</b> menu' 'To proceed further, you need to get a network connection in this menu' 'If you understand this, please enter this simple affirmation I have prepaired for you <3' '' (+ (+ '<b>' affirmation) '</b>') ''))
    (gl-break-silence ((at header 'join') header (char 10)))
    (while (!= affirmation (user_input ':: ')) (begin
    (gl-break-silence 'You filled an affirmation incorrectly!')
    (gl-break-silence 'Please try again, you got this!!!')))
    (while (! (IsNetworkReachable)) (begin
    ((at (at globals 'command') 'air'))
    (if (! (IsNetworkReachable)) (begin
    (mari-printline 'Please connect to the network!')
    ((at (at globals 'command') 'pause') '3')))))
    ((at (at globals 'command') 'shell') 'exit " Awesome! Now run 5hell with this script again! (^.^ ) "')))
(defun NetworkLogic () (begin
    (mari-printline 'Network connection is present, running the network logic...')
    (if multiplayer? (begin
    (mari-printline 'Looking for three repositories...')
    ((at (at globals 'command') 'do') '3' 'netstalk " ^.*>1542 .*>open .*>repository .*$ " | aptm -a')
    (mari-printline 'Installing the hacking utilities...')
    ((at (at globals 'command') 'aptm') '-i' 'crypto.so' '/lib')
    ((at (at globals 'command') 'aptm') '-i' 'metaxploit.so' '/lib')
    ((at (at globals 'command') 'aptm') '--hotswap')
    ((at (at globals 'command') 'aptm') '-i' 'AdminMonitor.exe' '/usr/bin')
    ((at (at globals 'command') 'usr') '-r' 'guest' '/usr/bin/AdminMonitor.exe')
    ((at (at globals 'command') 'grp') '-r' 'guest' '/usr/bin/AdminMonitor.exe')
    ((at (at globals 'command') 'perms') 'o+rwx' '/usr/bin/AdminMonitor.exe')
    ((at (at globals 'command') 'perms') 'g+rwx' '/usr/bin/AdminMonitor.exe')
    ((at (at globals 'command') 'perms') 'u+rwx' '/usr/bin/AdminMonitor.exe')))
    (def affirmation (RandomAffirmation))
    (def header (array '<u>An important warning!</u>' '' 'You are about to be faced with <b>kore -r</b> prompt' 'In this prompt, you absolutely must simply press enter for a quick setup!' 'After this, you may encounter <b>kraken</b> Map.conf prompt' 'It is <b>kraken</b> attempting to create Map.conf, so simply press enter as well' 'If you understand this, please enter this simple affirmation I have prepaired for you <3' '' (+ (+ '<b>' affirmation) '</b>') ''))
    (gl-break-silence ((at header 'join') header (char 10)))
    (while (!= affirmation (user_input ':: ')) (begin
    (gl-break-silence 'You filled an affirmation incorrectly!')
    (gl-break-silence 'Please try again, you got this!!!')))
    (mari-printline 'Regenerating the rkit...')
    ((at (at globals 'command') 'kore') '-r')
    (if multiplayer? (begin
    (mari-printline 'Making up proxy of three NPCs...')
    ((at (at globals 'command') 'kraken') '-r' '3')
    ((at (at globals 'command') 'undercover') '-b' '-c')))
    (mari-printline 'The setup is done! <3')
    null))
(if (!= ((at (at globals 'command') 'whoami')) 'root') (begin
    (mari-printline 'Root access is neccessary for this script!')
    null)
(begin
    (if (! multiplayer?) (begin
    (mari-printline 'Not in the multiplayer, running the stripped-down version...')
    ((at (at globals 'command') 'pause') '3')))
    (if (! (IsNetworkReachable)) (begin
    (NoNetworkLogic))
(begin
    (NetworkLogic)))))