;; One branch
(if true (begin
    (print true)))
;; Two branches
(if true (begin
    (print true))
(begin
    (print false)))
;; Multiple branches
(if true (begin
    (print true))
(if false (begin
    (print false))
(if true (begin
    (print true))
(begin
    (print false)))))
;; Logical operators
(if (! a) (begin
    )
(if (& a b) (begin
    )
(if (| a b) (begin
    )
(if (| (| (| (| (| (== a b) (!= a b)) (> a b)) (< a b)) (>= a b)) (<= a b)) (begin
    )))))
;; Complex logical operators
(if (| (& a b) (== a b)) (begin
    ))