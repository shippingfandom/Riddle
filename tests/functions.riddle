// Host function with zero arguments
function HostFZero() {
    print("Host function with zero arguments");
}
// Glosure function with zero arguments
defun GlosureFZero() {
    print("Glosure function with zero arguments");
}
// Host function reference
print(["HostFZero reference", HostFZero]);
// Glosure function referenece
print(["GlosureFZero reference", GlosureFZero]);
// Host function call
HostFZero();
// Glosure function call
GlosureFZero();

// Host function with one argument
function HostFOne(a) {
    print(["Host function with one argument", a]);
}
// Glosure function with one argument
defun GlosureFOne(a) {
    print(["Glosure function with one argument", a]);
}
// Host function call
HostFOne(1337);
// Glosure function call
GlosureFOne(1337);

// Host function with one default argument
function HostFOneDefault(a = 0) {
    print(["Host function with one default argument", a]);
}
// Glosure function with one default argument
defun GlosureFOneDefault(a = 0) {
    print(["Glosure function with one default argument", a]);
}
// Host function call
HostFOneDefault();
// Glosure function call
GlosureFOneDefault();
// Host function call
HostFOneDefault(1337);
// Glosure function call
GlosureFOneDefault(1337);

// Namespace
namespace = {};
namespace.variables = {};
namespace.functions = {};

// Complex arrow call
namespace.variables.root = get_shell()->host_computer()->File("/");

// Complex builtin reference
namespace.variables.shell = get_shell();
print(["shell.host_computer reference", namespace.variables.shell.host_computer]);

// Namespace builtin function
function namespace.functions.Host(a, b = 1) {
    return a + b;
}
// Namespace Glosure function
function namespace.functions.Glosure(a, b = 1) {
    return a + b;
}

// Namespace builtin function call
namespace.functions.Host(1, 2);
// Namespace Glosure function call
namespace.functions.Glosure(1, 2);


// Very complex namespace Glosure function
namespace.functions.another = {};
defun namespace.functions.another.Glosure() {

}
// Very complex namespace Glosure function call
namespace.functions.another.Glosure();
